generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  badgeNumber   String?
  currentGrade  String?  // e.g. "Grassroots", "Grade 8", "Grade 7"
  state         String?  // US state association
  emailVerified              Boolean   @default(false)
  emailVerificationCode      String?   // SHA-256 hash of the 6-digit code
  emailVerificationExpiry    DateTime?
  emailVerificationAttempts  Int       @default(0)
  emailVerificationSentAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  matches       Match[]
}

model Match {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])

  // Match identity
  date              DateTime
  venue             String
  field             String?
  competitionName   String
  ageGroup          String    // e.g. "U14", "U16", "Adult"
  gender            String    // "Boys", "Girls", "Men", "Women", "Coed"
  competitionLevel  String    // "Recreational", "Competitive", "State Cup", "Regional", "National"
  homeTeam          String
  awayTeam          String
  homeJerseyColor   String?
  awayJerseyColor   String?
  homeHeadCoach     String?
  awayHeadCoach     String?
  halfLength        Int       @default(45)  // minutes per half, e.g. 25/30/35/40/45
  overtimePossible  Boolean   @default(false) // if false, hide ET/PK periods and fields

  // Result
  homeScore         Int       @default(0)
  awayScore         Int       @default(0)
  halfTimeHomeScore Int?
  halfTimeAwayScore Int?
  extraTime         Boolean   @default(false)
  penalties         Boolean   @default(false)

  // Official's role
  role              String    // "Center", "AR1", "AR2"
  centerRefName     String?
  centerRefBadge    String?

  // Post-match notes
  narrative         String?
  matchAbandoned    Boolean   @default(false)
  abandonReason     String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  events              GameEvent[]
  players             Player[]
  supplementalReports SupplementalReport[]
}

model GameEvent {
  id            String   @id @default(cuid())
  matchId       String
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  eventType     String   // "goal", "yellow_card", "red_card", "substitution", "injury", "note"
  period        String   // "1", "2", "et1", "et2", "penalties"
  minute        Int
  stoppageTime  Int?
  team          String   // "home", "away"

  playerName    String?
  playerNumber  String?

  // Type-specific details
  detail        Json?

  createdAt     DateTime @default(now())

  supplementalReport SupplementalReport?
}

model SupplementalReport {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Linked to the specific triggering event (red card, etc.) — optional for non-event incidents
  gameEventId String?  @unique
  gameEvent   GameEvent? @relation(fields: [gameEventId], references: [id], onDelete: SetNull)

  // Incident classification
  // send_off | coach_dismissal | referee_abuse | referee_assault | serious_injury | abandonment | other
  incidentType  String

  // Who — auto-populated from the linked event where applicable
  team          String?   // "home", "away"
  playerName    String?
  playerNumber  String?
  officialName  String?   // for coach/team official dismissals
  officialRole  String?   // "Head Coach", "Assistant Coach", "Team Manager", "Other"

  // When / where
  minute        Int?
  stoppageTime  Int?
  period        String?
  fieldLocation String?   // free text: "attacking penalty area", "center circle", etc.

  // Offense code — mirrors the red card reason
  offenseCode   String?

  // Main narrative (plain language, facts only, Laws of the Game terminology)
  narrative     String?

  // Offense-specific structured data — shape varies by incidentType, see lib/supplementalTypes.ts
  details       Json?

  // Submission tracking
  // draft | complete | submitted
  status        String    @default("draft")
  submittedAt   DateTime?
  // Comma-separated list of destinations: "WYS", "WPL", "WASA", "email", "other"
  submittedTo   String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Player {
  id           String  @id @default(cuid())
  matchId      String
  match        Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)

  team         String  // "home", "away"
  name         String
  number       String
  isStarter    Boolean @default(true)
}
